class Student {
    private String name;
    private int id;
    private double cgpa;
    void setName(String n) {
        name = n;
    }
    void setId(int i) {
        id = i;
    }
    void setCgpa(double c) {
        cgpa = c;
    }
    String getName() {
        return name;
    }
    int getId() {
        return id;
    }
    double getCgpa() {
        return cgpa;
    }
}
public class Main {
    public static void main(String[] args) {
        Student s1 = new Student();
        s1.setName("Rahim");
        s1.setId(101);
        s1.setCgpa(3.85);
        System.out.println("Student Name: " + s1.getName());
        System.out.println("Student ID: " + s1.getId());
        System.out.println("Student CGPA: " + s1.getCgpa());
    }
}
